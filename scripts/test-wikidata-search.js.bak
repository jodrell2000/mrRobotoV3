#!/usr/bin/env node

/**
 * Test script for VerificationService
 * Validates Wikipedia, Wikidata, and MusicBrainz integration
 * 
 * Usage: node scripts/test-wikidata-search.js
 * 
 * Edit the TEST_ARTIST and TEST_TRACK variables below to test different combinations
 */

const VerificationService = require( '../src/services/verificationService.js' );
const fs = require( 'fs' );
const path = require( 'path' );

// ============ EDIT THESE TO TEST DIFFERENT ARTISTS/TRACKS ============
const TEST_ARTIST = 'Kon Kan';
const TEST_TRACK = 'Hooks in you';
// =====================================================================

// Color codes for console output
const colors = {
    reset: '\x1b[0m',
    bright: '\x1b[1m',
    green: '\x1b[32m',
    cyan: '\x1b[36m',
    yellow: '\x1b[33m',
    blue: '\x1b[34m',
    red: '\x1b[31m'
};

function log ( color, label, message ) {
    console.log( `${ colors[ color ] }${ label }${ colors.reset } ${ message }` );
}

// Mock logger for VerificationService
const mockLogger = {
    debug: ( msg ) => console.log( `${ colors.yellow }[DEBUG]${ colors.reset } ${ msg }` ),
    info: ( msg ) => console.log( `${ colors.green }[INFO]${ colors.reset } ${ msg }` ),
    warn: ( msg ) => console.log( `${ colors.yellow }[WARN]${ colors.reset } ${ msg }` ),
    error: ( msg ) => console.log( `${ colors.red }[ERROR]${ colors.reset } ${ msg }` )
};


function section ( title ) {
    console.log( `\n${ colors.bright }${ colors.blue }${ '='.repeat( 70 ) }${ colors.reset }` );
    console.log( `${ colors.bright }${ colors.blue }${ title }${ colors.reset }` );
    console.log( `${ colors.bright }${ colors.blue }${ '='.repeat( 70 ) }${ colors.reset }\n` );
}

async function main () {
    console.log( `${ colors.bright }${ colors.cyan }Mr. Roboto V3 - VerificationService Test${ colors.reset }` );
    console.log( `${ colors.cyan }Testing verification of "${ TEST_TRACK }" by ${ TEST_ARTIST }${ colors.reset }\n` );

    // Initialize verification service
    section( 'Initializing VerificationService' );
    const verificationService = new VerificationService( { logger: mockLogger } );
    await verificationService.initialize();

    // Run verification
    section( 'Running Verification' );
    log( 'cyan', '[VERIFY]', `Searching for "${ TEST_ARTIST } - ${ TEST_TRACK }"...` );

    let verifiedDataSummary;
    try {
        const result = await verificationService.verify( `${ TEST_ARTIST } - ${ TEST_TRACK }` );

        if ( result.found ) {
            log( 'green', '✓', `Successfully verified data` );
            verifiedDataSummary = result.data;

            // Display verified data
            section( 'Verified Information Summary' );

            console.log( `${ colors.cyan }Track Information:${ colors.reset }` );
            console.log( `  Title: ${ verifiedDataSummary.track.title }` );
            if ( verifiedDataSummary.track.artist ) {
                console.log( `  Artist: ${ verifiedDataSummary.track.artist }` );
            }
            if ( verifiedDataSummary.track.releaseDate ) {
                console.log( `  Release Date: ${ verifiedDataSummary.track.releaseDate }` );
            }
            if ( verifiedDataSummary.track.categories?.length > 0 ) {
                console.log( `  Categories: ${ verifiedDataSummary.track.categories.join( ', ' ) }` );
            }
            if ( verifiedDataSummary.track.wikidata?.qid ) {
                console.log( `  Wikidata ID: ${ verifiedDataSummary.track.wikidata.qid }` );
            }
            if ( verifiedDataSummary.track.album ) {
                console.log( `  Album: ${ verifiedDataSummary.track.album.title }` );
            }

            console.log( `\n${ colors.cyan }Artist Information:${ colors.reset }` );
            console.log( `  Name: ${ verifiedDataSummary.artist.title }` );
            if ( verifiedDataSummary.artist.founded ) {
                console.log( `  Founded: ${ verifiedDataSummary.artist.founded }` );
            }
            if ( verifiedDataSummary.artist.country ) {
                console.log( `  Country: ${ verifiedDataSummary.artist.country }` );
            }
            if ( verifiedDataSummary.artist.categories?.length > 0 ) {
                console.log( `  Categories: ${ verifiedDataSummary.artist.categories.join( ', ' ) }` );
            }
            if ( verifiedDataSummary.artist.wikidata?.qid ) {
                console.log( `  Wikidata ID: ${ verifiedDataSummary.artist.wikidata.qid }` );
            }
        } else {
            log( 'red', '✗', `Verification failed: ${ result.error }` );
            verifiedDataSummary = null;
        }
    } catch ( err ) {
        log( 'red', '✗', `Error during verification: ${ err.message }` );
        verifiedDataSummary = null;
    }

    // Display JSON output
    section( 'JSON Output' );
    if ( verifiedDataSummary ) {
        console.log( JSON.stringify( verifiedDataSummary, null, 2 ) );

        // Save to file
        const resultsFile = path.join( __dirname, 'test-wikidata-results.json' );
        const results = {
            timestamp: new Date().toISOString(),
            query: `${ TEST_ARTIST } - ${ TEST_TRACK }`,
            verifiedData: verifiedDataSummary
        };
        fs.writeFileSync( resultsFile, JSON.stringify( results, null, 2 ) );
        console.log( `\n${ colors.cyan }Results saved to: scripts/test-wikidata-results.json${ colors.reset }` );
    } else {
        console.log( 'No data to display' );
    }

    console.log( `\n${ colors.green }✓ Test complete!${ colors.reset }\n` );
}

main().catch( err => {
    log( 'red', '[FATAL]', err.message );
    process.exit( 1 );
} );
