# Check the docs/SETTING_UP_YOUR_ENVIRONMENT.md for full details on what to do with this file and how to find all the required information

# Static info...don't change these
TTFM_GATEWAY_BASE_URL="https://gateway.prod.tt.fm"
COMETCHAT_API_KEY=193427bb5702bab7
OPENCHAT_BASE_URL="https://openchat.prod.tt.fm/"

# User token for the Bot to authenticate against the site
BOT_USER_TOKEN=paste-your-bot-token-here

# CometChat/OpenChat Authentication Token
# NOTE: This token is now fetched automatically from the Gateway API during startup
# Do NOT set this variable unless specifically instructed for debugging purposes
# COMETCHAT_AUTH_TOKEN=

# Other environment variables would go here
BOT_UID=paste-your-bot-uuid-here
HANGOUT_ID=paste-hangout-uuid-here
COMMAND_SWITCH="/"

# Logging configuration
LOG_LEVEL=off
SOCKET_MESSAGE_LOG_LEVEL=OFF

# Google AI / Gemini API key for machine learning features
googleAIKey=paste-your-google-ai-api-key-here

# Web documentation server (automatically configured during deployment)
# WEB_DOCS_URL=http://YOUR-IP-ADDRESS:8080
# PORT=8080
